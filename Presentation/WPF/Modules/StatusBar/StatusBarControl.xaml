<UserControl x:Class="Zander.Modules.StatusBar.StatusBarControl"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
	<StatusBar>
        <StatusBarItem>
            <ProgressBar 
                Width="96px" 
                Height="16px"
                Maximum="{Binding Path=StatusBarModel.TotalServers}" 
                Value="{Binding Path=StatusBarModel.ServersQueried}" />
        </StatusBarItem>
		<StatusBarItem>
			<TextBlock Text="{Binding Path=StatusBarModel.ServerQueryStatus, Mode=OneWay}" />
		</StatusBarItem>
	</StatusBar>
</UserControl>
