<UserControl x:Class="Zander.Modules.ServerBrowser.ServerBrowserControl"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:conv="clr-namespace:Zander.Modules.ServerBrowser.Converters">
	<UserControl.Resources>
		<conv:CollectionToCommaList x:Key="CollectionToCommaList" />
	</UserControl.Resources>
	<DataGrid 
        AutoGenerateColumns="False" 
        ItemsSource="{Binding Path=Model.Servers}" 
        IsReadOnly="True" 
        HeadersVisibility="Column"
        SelectedItem="{Binding Path=Model.SelectedServer}"
        MouseDoubleClick="DataGridMouseDoubleClick">
		<DataGrid.Columns>
			<DataGridTextColumn Header="Name" Binding="{Binding Path=DisplayName}" />
			<DataGridTextColumn Header="Players" Binding="{Binding Path=Players}" />
			<DataGridTextColumn Header="Current Map" Binding="{Binding Path=CurrentMap}" />
			<DataGridTextColumn Header="IWad" Binding="{Binding Path=IWad}" />
			<DataGridTextColumn Header="Game Name" Binding="{Binding Path=GameName}" />
			<DataGridTextColumn Header="PWads" Binding="{Binding Path=PWads, Converter={StaticResource ResourceKey=CollectionToCommaList}}" />
			<DataGridTextColumn Header="Address" Binding="{Binding Path=Address}" />
		</DataGrid.Columns>
	</DataGrid>
</UserControl>
